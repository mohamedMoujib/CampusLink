<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/23.0.2"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.campusLink.controllers.CalendarViewController"
      stylesheets="@../styles/app.css"
      prefWidth="800" prefHeight="600"
      styleClass="calendar-view">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- En-tête avec navigation -->
    <HBox alignment="CENTER" spacing="15" styleClass="calendar-header">
        <Button fx:id="prevMonthBtn" text="◀" styleClass="calendar-nav-btn"/>
        <Label fx:id="monthYearLabel" styleClass="calendar-month-label"/>
        <Button fx:id="nextMonthBtn" text="▶" styleClass="calendar-nav-btn"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="✕" styleClass="calendar-nav-btn" onAction="#onClose"/>
    </HBox>

    <!-- Grille du calendrier -->
    <GridPane fx:id="calendarGrid" VBox.vgrow="ALWAYS" styleClass="calendar-grid">
        <!-- Les cellules seront ajoutées dynamiquement -->
    </GridPane>
</VBox>