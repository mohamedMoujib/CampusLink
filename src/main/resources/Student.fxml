<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.Student_controller"
            prefWidth="1400" prefHeight="900"
            stylesheets="/Styles/student.css"
            styleClass="root">

    <!-- TOP BAR -->
    <top>
        <VBox>
            <!-- Header principal -->
            <HBox spacing="20" alignment="CENTER_LEFT" styleClass="header-container">

                <!-- Logo -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="📚" styleClass="logo-box"/>
                    <VBox>
                        <Label text="EduMarket" styleClass="logo-title"/>
                        <Label text="Espace Étudiant" styleClass="logo-subtitle"/>
                    </VBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- User info -->
                <HBox spacing="15" alignment="CENTER">
                    <Button text="🔔" styleClass="notification-btn"/>
                    <VBox alignment="CENTER_RIGHT">
                        <Label text="Marie Dubois" styleClass="user-name"/>
                        <Label text="marie.dubois@univ.fr" styleClass="user-email"/>
                    </VBox>
                    <Label text="👤" styleClass="user-avatar"/>
                    <Button text="⎋" styleClass="logout-btn"/>
                </HBox>
            </HBox>

            <!-- Menu Navigation -->
            <HBox spacing="30" alignment="CENTER_LEFT" styleClass="menu-container">

                <HBox spacing="8" alignment="CENTER" styleClass="menu-item-active">
                    <Label text="🔍" styleClass="menu-icon"/>
                    <Label text="Rechercher des services"/>
                </HBox>

                <HBox spacing="8" alignment="CENTER" styleClass="menu-item" onMouseClicked="#goToPublications" style="-fx-cursor: hand;">
                    <Label text="📢" styleClass="menu-icon"/>
                    <Label text="Publications"/>
                </HBox>

                <HBox spacing="8" alignment="CENTER" styleClass="menu-item" onMouseClicked="#goToMesDemandes" style="-fx-cursor: hand;">
                    <Label text="📋" styleClass="menu-icon"/>
                    <Label text="Mes demandes"/>
                </HBox>

                <HBox spacing="8" alignment="CENTER" styleClass="menu-item">
                    <Label text="📅" styleClass="menu-icon"/>
                    <Label text="Mes réservations"/>
                </HBox>

                <HBox spacing="8" alignment="CENTER" styleClass="menu-item">
                    <Label text="💳" styleClass="menu-icon"/>
                    <Label text="Paiements"/>
                </HBox>

                <HBox spacing="8" alignment="CENTER" styleClass="menu-item">
                    <Label text="⭐" styleClass="menu-icon"/>
                    <Label text="Mes avis"/>
                </HBox>

                <HBox spacing="8" alignment="CENTER" styleClass="menu-item">
                    <Label text="👤" styleClass="menu-icon"/>
                    <Label text="Mon profil"/>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Voir mes services"
                        onAction="#goToServices"
                        styleClass="services-btn"/>
            </HBox>
        </VBox>
    </top>

    <!-- CONTENT -->
    <center>
        <VBox spacing="25">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <!-- Barre de recherche -->
            <HBox styleClass="search-container">
                <Label text="🔍" styleClass="search-icon"/>
                <TextField fx:id="searchField"
                           promptText="Rechercher un service, une matière, un tuteur..."
                           styleClass="search-input"/>
            </HBox>

            <!-- Filtres -->
            <HBox spacing="20" alignment="CENTER_LEFT">
                <VBox spacing="8" styleClass="filter-group">
                    <Label text="Catégorie" styleClass="filter-label"/>
                    <ComboBox fx:id="categorieCombo"
                              promptText="Tous"
                              styleClass="filter-combo"
                              prefWidth="280"/>
                </VBox>

                <VBox spacing="8" styleClass="filter-group">
                    <Label text="Tarif" styleClass="filter-label"/>
                    <ComboBox fx:id="tarifCombo"
                              promptText="Tous les tarifs"
                              styleClass="filter-combo"
                              prefWidth="280"/>
                </VBox>

                <VBox spacing="8" styleClass="filter-group">
                    <Label text="Trier par" styleClass="filter-label"/>
                    <ComboBox fx:id="trierCombo"
                              promptText="Meilleure note"
                              styleClass="filter-combo"
                              prefWidth="280"/>
                </VBox>
            </HBox>

            <!-- Container des services -->
            <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                <GridPane fx:id="servicesGrid"
                          hgap="20"
                          vgap="20"
                          styleClass="services-grid"/>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
