<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.Demande_controller"
            style="-fx-background-color: #f9fafb;">

    <!-- TOP BAR -->
    <top>
        <VBox spacing="20" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #e5e5e5; -fx-border-width: 0 0 1 0;">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="Mes Demandes"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="← Retour aux Services"
                        onAction="#goBackToServices"
                        style="-fx-background-color: #e5e7eb; -fx-text-fill: #374151; -fx-font-size: 14px; -fx-font-weight: 600; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>

                <Button text="+ Nouvelle Demande"
                        onAction="#goToCreateDemande"
                        style="-fx-background-color: #5B5FED; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12 24; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(91,95,237,0.3), 8, 0, 0, 2);"/>
            </HBox>

            <!-- Statistics Cards -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <!-- En Attente -->
                <VBox spacing="8" style="-fx-background-color: #fef3c7; -fx-padding: 15; -fx-background-radius: 10; -fx-min-width: 150;">
                    <Label text="⏳ En attente" style="-fx-font-size: 12px; -fx-text-fill: #92400e; -fx-font-weight: bold;"/>
                    <Label fx:id="statsEnAttente" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #92400e;"/>
                </VBox>

                <!-- Confirmées -->
                <VBox spacing="8" style="-fx-background-color: #dbeafe; -fx-padding: 15; -fx-background-radius: 10; -fx-min-width: 150;">
                    <Label text="✓ Confirmées" style="-fx-font-size: 12px; -fx-text-fill: #1e40af; -fx-font-weight: bold;"/>
                    <Label fx:id="statsConfirmee" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1e40af;"/>
                </VBox>

                <!-- Refusées -->
                <VBox spacing="8" style="-fx-background-color: #fee2e2; -fx-padding: 15; -fx-background-radius: 10; -fx-min-width: 150;">
                    <Label text="✗ Refusées" style="-fx-font-size: 12px; -fx-text-fill: #991b1b; -fx-font-weight: bold;"/>
                    <Label fx:id="statsRefusee" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #991b1b;"/>
                </VBox>

                <!-- Terminées -->
                <VBox spacing="8" style="-fx-background-color: #d1fae5; -fx-padding: 15; -fx-background-radius: 10; -fx-min-width: 150;">
                    <Label text="✓ Terminées" style="-fx-font-size: 12px; -fx-text-fill: #065f46; -fx-font-weight: bold;"/>
                    <Label fx:id="statsTerminee" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #065f46;"/>
                </VBox>
            </HBox>

            <!-- Filter Bar -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="Filtrer par statut:"
                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-weight: 600;"/>

                <ComboBox fx:id="filterStatusCombo"
                          promptText="Tous les statuts"
                          style="-fx-min-width: 200; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER - Demandes Cards Container -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: #f9fafb; -fx-background: #f9fafb;">
            <VBox style="-fx-background-color: #f9fafb;">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <FlowPane fx:id="demandesContainer"
                          hgap="20"
                          vgap="20"
                          alignment="TOP_LEFT"
                          style="-fx-background-color: #f9fafb;"/>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
