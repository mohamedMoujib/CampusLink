<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.campusLink.controllers.TutorDashboardController"
            styleClass="root"
            stylesheets="@/Styles/reviews.css">>

    <!-- TOP NAVBAR -->
    <top>
        <VBox>
            <!-- Header avec logo et user -->
            <HBox alignment="CENTER_LEFT" styleClass="top-header">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="📚" style="-fx-font-size: 24px;"/>
                    <VBox spacing="2">
                        <Label text="CampusLink" styleClass="logo-tutor"/>
                        <Label text="Espace Tuteur" style="-fx-font-size:11px; -fx-text-fill:#666;"/>
                    </VBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="20" alignment="CENTER_RIGHT">
                    <Label text="🔔" style="-fx-font-size: 20px;"/>
                    <VBox alignment="CENTER_RIGHT" spacing="2">
                        <Label text="Sami Prestataire" style="-fx-font-weight:bold; -fx-font-size:13px;"/>
                        <Label text="sami@pro.tn" style="-fx-font-size:11px; -fx-text-fill:#666;"/>
                    </VBox>
                    <Label text="👤" style="-fx-font-size: 24px;"/>
                </HBox>
            </HBox>

            <!-- Navigation tabs -->
            <HBox spacing="0" styleClass="nav-tabs">
                <Button text="📊 Tableau de bord" styleClass="nav-tab-active-tutor"/>
                <Button text="🛠️ Mes services" styleClass="nav-tab-tutor"/>
                <Button text="📅 Réservations" styleClass="nav-tab-tutor"/>
                <Button text="⭐ Avis reçus" styleClass="nav-tab-tutor" onAction="#goToReviews"/>
                <Button text="💰 Revenus" styleClass="nav-tab-tutor"/>
                <Button text="👤 Mon profil" styleClass="nav-tab-tutor"/>
            </HBox>
        </VBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="30" style="-fx-padding: 40 60 40 60;">

                <!-- Page Header -->
                <Label text="📊 Tableau de bord" styleClass="page-title"/>

                <!-- 🔥 STATISTIQUES PRINCIPALES (KPIs) - 3 COLONNES -->
                <GridPane hgap="20" vgap="20">
                    <!-- Ligne 1 -->
                    <VBox spacing="10" styleClass="stats-card-large" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="🛠️" style="-fx-font-size: 32px;"/>
                            <VBox spacing="3">
                                <Label text="Services actifs" style="-fx-font-size:12px; -fx-text-fill:#6b7280;"/>
                                <Label fx:id="totalServicesLabel" text="0" style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#059669;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox spacing="10" styleClass="stats-card-large" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="📅" style="-fx-font-size: 32px;"/>
                            <VBox spacing="3">
                                <Label text="Réservations totales" style="-fx-font-size:12px; -fx-text-fill:#6b7280;"/>
                                <Label fx:id="totalReservationsLabel" text="0" style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#059669;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox spacing="10" styleClass="stats-card-large" GridPane.columnIndex="2" GridPane.rowIndex="0">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="💰" style="-fx-font-size: 32px;"/>
                            <VBox spacing="3">
                                <Label text="Revenus totaux" style="-fx-font-size:12px; -fx-text-fill:#6b7280;"/>
                                <Label fx:id="totalRevenueLabel" text="0.00 €" style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#059669;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Ligne 2 -->
                    <VBox spacing="10" styleClass="stats-card-large" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="⭐" style="-fx-font-size: 32px;"/>
                            <VBox spacing="3">
                                <Label text="Note moyenne" style="-fx-font-size:12px; -fx-text-fill:#6b7280;"/>
                                <Label fx:id="averageRatingLabel" text="0.0" style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#fbbf24;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox spacing="10" styleClass="stats-card-large" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="🏆" style="-fx-font-size: 32px;"/>
                            <VBox spacing="3">
                                <Label text="Points de confiance" style="-fx-font-size:12px; -fx-text-fill:#6b7280;"/>
                                <Label fx:id="trustPointsLabel" text="0" style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#059669;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox spacing="10" styleClass="stats-card-large" GridPane.columnIndex="2" GridPane.rowIndex="1">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="💬" style="-fx-font-size: 32px;"/>
                            <VBox spacing="3">
                                <Label text="Total d'avis" style="-fx-font-size:12px; -fx-text-fill:#6b7280;"/>
                                <Label fx:id="totalReviewsLabel" text="0" style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#059669;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </GridPane>

                <!-- 🔥 GRAPHIQUES EN 2 COLONNES -->
                <GridPane hgap="20" vgap="20">
                    <!-- Graphique Mensuel -->
                    <VBox spacing="15" styleClass="chart-container" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2">
                        <Label text="📈 Évolution mensuelle" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                        <LineChart fx:id="monthlyChart" prefHeight="300" animated="false">
                            <xAxis>
                                <CategoryAxis label="Mois" tickLabelFill="#374151" style="-fx-tick-label-fill: #374151;"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Valeur" tickLabelFill="#374151" style="-fx-tick-label-fill: #374151;"/>
                            </yAxis>
                        </LineChart>
                    </VBox>

                    <!-- Top Services -->
                    <VBox spacing="15" styleClass="chart-container" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label text="🏆 Top 5 Services" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                        <BarChart fx:id="topServicesChart" prefHeight="300" animated="false">
                            <xAxis>
                                <CategoryAxis label="Services" tickLabelFill="#374151" style="-fx-tick-label-fill: #374151;"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Réservations" tickLabelFill="#374151" style="-fx-tick-label-fill: #374151;"/>
                            </yAxis>
                        </BarChart>
                    </VBox>

                    <!-- Distribution des notes -->
                    <VBox spacing="15" styleClass="chart-container" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label text="📊 Répartition des notes" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                        <PieChart fx:id="ratingDistributionChart" prefHeight="300" animated="false" legendVisible="true"/>
                    </VBox>
                </GridPane>

                <!-- 🔥 AVIS RÉCENTS -->
                <VBox spacing="15" styleClass="recent-section">
                    <Label text="💬 Derniers avis reçus" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                    <VBox fx:id="recentReviewsContainer" spacing="12"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>