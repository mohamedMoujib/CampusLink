<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane fx:id="rootPane"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.campusLink.controllers.LoginController"
           styleClass="root-pane"
           stylesheets="@/Styles/Login.css">

    <!-- Declare ToggleGroup -->
    <fx:define>
        <ToggleGroup fx:id="roleGroup"/>
    </fx:define>

    <VBox alignment="CENTER" styleClass="background">

        <VBox styleClass="login-card"
              alignment="CENTER"
              spacing="20"
              maxWidth="400">

            <!-- Logo -->
            <StackPane styleClass="logo-circle">
                <Text text="🎓" styleClass="logo-icon"/>
            </StackPane>

            <!-- Title -->
            <VBox alignment="CENTER" spacing="5">
                <Text text="CampusLink" styleClass="title"/>
                <Text text="Plateforme de Services Étudiants" styleClass="subtitle"/>
            </VBox>

            <!-- Account Type -->
            <VBox spacing="10">
                <Text text="Type de compte" styleClass="label-text"/>

                <HBox spacing="10" alignment="CENTER">
                    <ToggleButton fx:id="btnEtudiant"
                                  text="Étudiant"
                                  toggleGroup="$roleGroup"
                                  selected="true"
                                  styleClass="role-btn, role-btn-selected"/>

                    <ToggleButton fx:id="btnPrestataire"
                                  text="Prestataire"
                                  toggleGroup="$roleGroup"
                                  styleClass="role-btn"/>

                    <ToggleButton fx:id="btnAdmin"
                                  text="Admin"
                                  toggleGroup="$roleGroup"
                                  styleClass="role-btn"/>
                </HBox>
            </VBox>

            <!-- Email -->
            <VBox spacing="5">
                <Text text="Email" styleClass="label-text"/>
                <TextField fx:id="txtEmail"
                           promptText="votre@email.com"
                           styleClass="input-field-full"/>
                <Label fx:id="lblEmailError"
                       styleClass="error-label"
                       managed="false"
                       visible="false"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="5">
                <Text text="Mot de passe" styleClass="label-text"/>
                <PasswordField fx:id="txtPassword"
                               promptText="••••••••"
                               styleClass="input-field-full"/>
                <Label fx:id="lblPasswordError"
                       styleClass="error-label"
                       managed="false"
                       visible="false"/>
            </VBox>

            <!-- Remember + Forgot -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <CheckBox fx:id="chkRememberMe"
                          text="Se souvenir de moi"
                          styleClass="checkbox"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Hyperlink fx:id="linkForgotPassword"
                           text="Mot de passe oublié?"
                           styleClass="link"
                           onAction="#handleForgotPassword"/>
            </HBox>

            <!-- Login Button -->
            <Button fx:id="btnLogin"
                    text="Se connecter"
                    maxWidth="Infinity"
                    styleClass="btn-primary"
                    onAction="#handleLogin"/>

            <!-- Signup -->
            <HBox alignment="CENTER" spacing="5">
                <Text text="Vous n'avez pas de compte?"
                      styleClass="footer-text"/>

                <Hyperlink fx:id="linkSignup"
                           text="S'inscrire"
                           styleClass="link-primary"
                           onAction="#handleSignup"/>
            </HBox>

            <!-- Divider -->
            <HBox alignment="CENTER" spacing="10">
                <Region HBox.hgrow="ALWAYS" styleClass="divider-line"/>
                <Text text="ou" styleClass="divider-text"/>
                <Region HBox.hgrow="ALWAYS" styleClass="divider-line"/>
            </HBox>

            <!-- Bouton Google -->
            <Button fx:id="btnGoogleLogin"
                    onAction="#handleGoogleSignup"
                    styleClass="btn-google"
                    maxWidth="Infinity"
                    prefHeight="40">
                <graphic>
                    <HBox alignment="CENTER" spacing="10">
                        <Text text="G" styleClass="google-letter"/>
                        <Text text="Se connecter avec Google" styleClass="google-btn-text"/>
                    </HBox>
                </graphic>
            </Button>

            <VBox.margin>
                <Insets top="20" right="40" bottom="20" left="40"/>
            </VBox.margin>

        </VBox>
    </VBox>
</StackPane>
