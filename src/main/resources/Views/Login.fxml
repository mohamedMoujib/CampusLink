<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.campusLink.controllers.LoginController"
           styleClass="root-pane"
           stylesheets="@/Styles/Login.css">

    <!-- Declare ToggleGroup -->
    <fx:define>
        <ToggleGroup fx:id="roleGroup"/>
    </fx:define>

    <VBox alignment="CENTER" styleClass="background" prefWidth="Infinity"
          prefHeight="Infinity" >

        <VBox styleClass="login-card"
              alignment="CENTER"
              spacing="20"
              maxWidth="400">

            <!-- Logo -->
            <StackPane styleClass="logo-circle">
                <Text text="🎓" styleClass="logo-icon"/>
            </StackPane>

            <!-- Title -->
            <VBox alignment="CENTER" spacing="5">
                <Text text="CampusLink" styleClass="title"/>
                <Text text="Plateforme de Services Étudiants" styleClass="subtitle"/>
            </VBox>

            <!-- Account Type -->
            <VBox spacing="10">
                <Text text="Type de compte" styleClass="label-text"/>

                <HBox spacing="10" alignment="CENTER">
                    <ToggleButton fx:id="btnEtudiant"
                                  text="Étudiant"
                                  toggleGroup="$roleGroup"
                                  selected="true"
                                  styleClass="role-btn"/>

                    <ToggleButton fx:id="btnPrestataire"
                                  text="Prestataire"
                                  toggleGroup="$roleGroup"
                                  styleClass="role-btn"/>

                    <ToggleButton fx:id="btnAdmin"
                                  text="Admin"
                                  toggleGroup="$roleGroup"
                                  styleClass="role-btn"/>
                </HBox>
            </VBox>

            <!-- Email -->
            <VBox spacing="8">
                <Text text="Email" styleClass="label-text"/>

                <HBox styleClass="input-container">
                    <Text text="✉" styleClass="input-icon"/>
                    <TextField fx:id="txtEmail"
                               promptText="votre@email.com"
                               styleClass="input-field"/>
                </HBox>
            </VBox>

            <!-- Password -->
            <VBox spacing="8">
                <Text text="Mot de passe" styleClass="label-text"/>

                <HBox styleClass="input-container">
                    <Text text="🔒" styleClass="input-icon"/>
                    <PasswordField fx:id="txtPassword"
                                   promptText="••••••••"
                                   styleClass="input-field"/>
                </HBox>
            </VBox>

            <!-- Remember + Forgot -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <CheckBox fx:id="chkRememberMe"
                          text="Se souvenir de moi"
                          styleClass="checkbox"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Hyperlink fx:id="linkForgotPassword"
                           text="Mot de passe oublié?"
                           styleClass="link"/>
            </HBox>

            <!-- Login Button -->
            <Button fx:id="btnLogin"
                    text="Se connecter"
                    maxWidth="Infinity"
                    styleClass="btn-primary"
                    onAction="#handleLogin"/>

            <!-- Signup -->
            <HBox alignment="CENTER" spacing="5">
                <Text text="Vous n'avez pas de compte?"
                      styleClass="footer-text"/>

                <Hyperlink fx:id="linkSignup"
                           text="S'inscrire"
                           styleClass="link-primary"
                           onAction="#handleSignup"/>
            </HBox>

            <VBox.margin>
                <Insets top="20" right="40" bottom="20" left="40"/>
            </VBox.margin>

        </VBox>
    </VBox>
</StackPane>
