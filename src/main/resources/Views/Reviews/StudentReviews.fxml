<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.campusLink.controllers.reviews.StudentReviewController"
            prefWidth="1400" prefHeight="900"
            styleClass="root"
            stylesheets="/Styles/reviews.css">

    <!-- TOP NAVBAR -->
    <top>
        <VBox>
            <!-- Header avec logo et user -->
            <HBox alignment="CENTER_LEFT" styleClass="top-header">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="📚" style="-fx-font-size: 24px;"/>
                    <VBox spacing="2">
                        <Label text="CampusLink" styleClass="logo"/>
                        <Label text="Espace Étudiant" style="-fx-font-size:11px; -fx-text-fill:#666;"/>
                    </VBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="20" alignment="CENTER_RIGHT">
                    <Label text="🔔" style="-fx-font-size: 20px;"/>
                    <VBox alignment="CENTER_RIGHT" spacing="2">
                        <Label text="Marie Dubois" style="-fx-font-weight:bold; -fx-font-size:13px;"/>
                        <Label text="marie.dubois@univ.fr" style="-fx-font-size:11px; -fx-text-fill:#666;"/>
                    </VBox>
                    <Label text="👤" style="-fx-font-size: 24px;"/>
                </HBox>
            </HBox>

            <!-- Navigation tabs -->
            <HBox spacing="0" styleClass="nav-tabs">
                <Button text="🔍 Rechercher des services" styleClass="nav-tab"/>
                <Button text="📅 Mes réservations" styleClass="nav-tab"/>
                <Button text="💳 Paiements" styleClass="nav-tab"/>
                <Button text="⭐ Mes avis" styleClass="nav-tab-active"/>
                <Button text="👤 Mon profil" styleClass="nav-tab"/>
            </HBox>
        </VBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="20" style="-fx-padding: 40 60 40 60;">

            <!-- Page Header -->
            <HBox alignment="CENTER_LEFT">
                <Label text="Mes avis" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Laisser un avis"
                        styleClass="primary-button"
                        onAction="#showAddForm"/>
            </HBox>

            <!-- Formulaire (caché par défaut) -->
            <VBox fx:id="formContainer" spacing="15" styleClass="form-card">
                <Label fx:id="formTitle" text="Laisser un avis" styleClass="form-title"/>

                <!-- 🔥 SECTION NOTE AVEC ÉTOILES CLIQUABLES -->
                <VBox spacing="8">
                    <Label text="Votre note :" style="-fx-font-weight:bold; -fx-font-size:14px;"/>
                    <HBox fx:id="starsRatingBox" spacing="5"/>
                </VBox>

                <!-- COMMENTAIRE -->
                <VBox spacing="5">
                    <Label text="Votre commentaire :" style="-fx-font-weight:bold; -fx-font-size:14px;"/>
                    <TextArea fx:id="commentField"
                              promptText="Partagez votre expérience..."
                              prefHeight="100"
                              wrapText="true"
                              styleClass="comment-area"/>
                </VBox>

                <!-- BOUTONS -->
                <HBox spacing="10">
                    <Button fx:id="addButton"
                            text="Publier"
                            styleClass="primary-button"
                            onAction="#handleAddReview"/>

                    <Button text="Annuler"
                            styleClass="secondary-button"
                            onAction="#hideForm"/>
                </HBox>
            </VBox>

            <!-- Liste des avis -->
            <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                <VBox fx:id="reviewContainer" spacing="20"/>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>