<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane fx:id="rootPane"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.campusLink.controllers.ForgotPasswordController"
           styleClass="root-pane"
           stylesheets="@/Styles/Login.css">

    <VBox alignment="CENTER" styleClass="background">

        <VBox styleClass="login-card"
              alignment="CENTER"
              spacing="20"
              maxWidth="400">

            <!-- Logo -->
            <StackPane styleClass="logo-circle">
                <Text text="🔐" styleClass="logo-icon"/>
            </StackPane>

            <!-- Title -->
            <VBox alignment="CENTER" spacing="5">
                <Text text="Mot de passe oublié" styleClass="title"/>
                <Text text="Entrez votre email pour recevoir un code"
                      styleClass="subtitle" textAlignment="CENTER"/>
            </VBox>

            <!-- Email -->
            <VBox spacing="5">
                <Text text="Email" styleClass="label-text"/>
                <TextField fx:id="txtEmail"
                           promptText="votre@email.com"
                           styleClass="input-field-full"/>
                <Label fx:id="lblEmailError"
                       styleClass="error-label"
                       managed="false"
                       visible="false"/>
            </VBox>

            <!-- Send Code Button -->
            <Button fx:id="btnSendCode"
                    text="Envoyer le code"
                    maxWidth="Infinity"
                    styleClass="btn-primary"
                    onAction="#handleSendCode"/>

            <!-- Back to Login -->
            <HBox alignment="CENTER" spacing="5">
                <Text text="Vous vous souvenez?"
                      styleClass="footer-text"/>

                <Hyperlink fx:id="linkLogin"
                           text="Se connecter"
                           styleClass="link-primary"
                           onAction="#handleBackToLogin"/>
            </HBox>

            <VBox.margin>
                <Insets top="20" right="40" bottom="20" left="40"/>
            </VBox.margin>

        </VBox>
    </VBox>
</StackPane>
