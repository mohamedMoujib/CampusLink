<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.Publication_controller"
            prefWidth="1400" prefHeight="800"
            stylesheets="/Styles/student.css"
            styleClass="root">

    <!-- TOP BAR -->
    <top>
        <VBox>
            <!-- Header principal -->
            <HBox spacing="20" alignment="CENTER_LEFT" styleClass="header-container">

                <!-- Logo -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="📚" styleClass="logo-box"/>
                    <VBox>
                        <Label text="EduMarket" styleClass="logo-title"/>
                        <Label text="Espace Étudiant" styleClass="logo-subtitle"/>
                    </VBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- User info -->
                <HBox spacing="15" alignment="CENTER">
                    <Button text="🔔" styleClass="notification-btn"/>
                    <VBox alignment="CENTER_RIGHT">
                        <Label text="Marie Dubois" styleClass="user-name"/>
                        <Label text="marie.dubois@univ.fr" styleClass="user-email"/>
                    </VBox>
                    <Label text="👤" styleClass="user-avatar"/>
                    <Button text="⎋" styleClass="logout-btn"/>
                </HBox>
            </HBox>

            <!-- Menu Navigation -->
            <HBox spacing="30" alignment="CENTER_LEFT" styleClass="menu-container">

                <HBox spacing="8" alignment="CENTER" styleClass="menu-item"
                      onMouseClicked="#goToServices" style="-fx-cursor: hand;">
                    <Label text="🔍" styleClass="menu-icon"/>
                    <Label text="Rechercher des services"/>
                </HBox>

                <HBox spacing="8" alignment="CENTER" styleClass="menu-item-active">
                    <Label text="📢" styleClass="menu-icon"/>
                    <Label text="Publications"/>
                </HBox>

                <HBox spacing="8" alignment="CENTER" styleClass="menu-item">
                    <Label text="📅" styleClass="menu-icon"/>
                    <Label text="Mes réservations"/>
                </HBox>

                <HBox spacing="8" alignment="CENTER" styleClass="menu-item">
                    <Label text="💳" styleClass="menu-icon"/>
                    <Label text="Paiements"/>
                </HBox>

                <HBox spacing="8" alignment="CENTER" styleClass="menu-item">
                    <Label text="⭐" styleClass="menu-icon"/>
                    <Label text="Mes avis"/>
                </HBox>

                <HBox spacing="8" alignment="CENTER" styleClass="menu-item">
                    <Label text="👤" styleClass="menu-icon"/>
                    <Label text="Mon profil"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <!-- CONTENT -->
    <center>
        <VBox spacing="25">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <!-- Tabs and Create Button -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Button fx:id="allPublicationsTab"
                        text="📋 Toutes les publications"
                        onAction="#showAllPublications"
                        style="-fx-background-color: #5D5FEF; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20; -fx-cursor: hand; -fx-background-radius: 8; -fx-border-width: 0; -fx-font-weight: bold;">
                    <cursor><javafx.scene.Cursor fx:constant="HAND"/></cursor>
                </Button>

                <Button fx:id="myPublicationsTab"
                        text="👤 Mes publications"
                        onAction="#showMyPublications"
                        style="-fx-background-color: #f3f4f6; -fx-text-fill: #6b7280; -fx-font-size: 14px; -fx-padding: 10 20; -fx-cursor: hand; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-width: 1;">
                    <cursor><javafx.scene.Cursor fx:constant="HAND"/></cursor>
                </Button>

                <Button text="+ Ajouter une publication"
                        onAction="#goToCreatePublication"
                        style="-fx-background-color: #f3f4f6; -fx-text-fill: #6b7280; -fx-font-size: 14px; -fx-padding: 10 20; -fx-cursor: hand; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-width: 1;">
                    <cursor><javafx.scene.Cursor fx:constant="HAND"/></cursor>
                </Button>

                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Filters -->
            <HBox spacing="15" alignment="CENTER">
                <TextField fx:id="searchField"
                           promptText="Rechercher une publication..."
                           prefWidth="300"
                           style="-fx-background-color: white; -fx-border-color: #d1d5db; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 15; -fx-font-size: 14px;"/>

                <ComboBox fx:id="typeFilter"
                          promptText="Type"
                          prefWidth="200"
                          style="-fx-background-color: white; -fx-border-color: #d1d5db; -fx-border-radius: 8; -fx-background-radius: 8;"/>
            </HBox>

            <!--
                FIX: VBox.vgrow="ALWAYS" makes the ScrollPane fill remaining
                     vertical space so cards are not clipped.
                     Removed the inner wrapping VBox so fitToWidth reaches
                     the FlowPane directly.
            -->
            <ScrollPane VBox.vgrow="ALWAYS"
                        fitToWidth="true"
                        fitToHeight="false"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;">

                <FlowPane fx:id="publicationsContainer"
                          hgap="20"
                          vgap="20"
                          prefWrapLength="1340"
                          style="-fx-background-color: transparent; -fx-padding: 0 0 20 0;"/>

            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
