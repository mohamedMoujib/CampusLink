<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.campusLink.controllers.ViewInvoice"
            styleClass="root"
            stylesheets="@../Style/PaymentForm.css">

    <center>
        <VBox styleClass="form-card" spacing="20">
            <padding>
                <Insets top="40" right="60" bottom="40" left="60"/>
            </padding>

            <Label text="Mes factures" styleClass="form-title"/>

            <!-- FILTER BAR -->
            <HBox spacing="15" alignment="CENTER_LEFT">

                <TextField fx:id="searchField"
                           promptText="🔎 Rechercher (ID, détails...)"
                           prefWidth="250"/>

                <DatePicker fx:id="startDatePicker"
                            promptText="Date exacte"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="resultCountLabel"
                       text="Résultats : 0"
                       style="-fx-text-fill:#666; -fx-font-size:12px;"/>
            </HBox>

            <!-- TABLE -->
            <TableView fx:id="invoiceTable" prefHeight="420">
                <columns>
                    <TableColumn fx:id="paymentIdColumn" text="Payment ID" prefWidth="120"/>
                    <TableColumn fx:id="dateColumn" text="Date" prefWidth="180"/>
                    <TableColumn fx:id="detailsColumn" text="Détails" prefWidth="400"/>
                </columns>
            </TableView>

            <HBox spacing="15">
                <Button text="🗑 Supprimer la facture sélectionnée"
                        styleClass="primary-button"
                        onAction="#deleteInvoice"/>
            </HBox>

            <Label fx:id="messageLabel"/>
        </VBox>
    </center>

</BorderPane>