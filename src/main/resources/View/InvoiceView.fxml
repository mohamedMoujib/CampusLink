<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.campusLink.controllers.ViewInvoice"
            styleClass="root"
            stylesheets="@../Style/PaymentForm.css">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" styleClass="top-header">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="📚" style="-fx-font-size: 24px;"/>
                    <VBox spacing="2">
                        <Label text="CampusLink" styleClass="logo"/>
                        <Label text="Espace Étudiant" style="-fx-font-size:11px; -fx-text-fill:#666;"/>
                    </VBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="20" alignment="CENTER_RIGHT">
                    <Label text="🔔" style="-fx-font-size: 20px;"/>
                    <VBox alignment="CENTER_RIGHT" spacing="2">
                        <Label text="Marie Dubois" style="-fx-font-weight:bold; -fx-font-size:13px;"/>
                        <Label text="marie.dubois@univ.fr" style="-fx-font-size:11px; -fx-text-fill:#666;"/>
                    </VBox>
                    <Label text="👤" style="-fx-font-size: 24px;"/>
                </HBox>
            </HBox>

            <HBox spacing="0" styleClass="nav-tabs">
                <Button text="🔍 Rechercher des services" styleClass="nav-tab"/>
                <Button text="📅 Mes réservations" styleClass="nav-tab"/>
                <Button text="💳 Paiements"
                        styleClass="nav-tab"
                        onAction="#goToPayments"/>
                <Button text="📄 Mes factures"
                        styleClass="nav-tab-active"/>
                <Button text="👤 Mon profil" styleClass="nav-tab"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox styleClass="form-card" spacing="20">
            <padding>
                <Insets top="40" right="60" bottom="40" left="60"/>
            </padding>

            <Label text="Mes factures" styleClass="form-title"/>

            <TableView fx:id="invoiceTable" prefHeight="420">
                <columns>
                    <TableColumn fx:id="paymentIdColumn" text="Payment ID"/>
                    <TableColumn fx:id="dateColumn" text="Date"/>
                    <TableColumn fx:id="detailsColumn" text="Détails"/>
                </columns>
            </TableView>
            <HBox spacing="15">
                <Button text="🗑 Supprimer la facture sélectionnée"
                        styleClass="primary-button"
                        onAction="#deleteInvoice"/>
            </HBox>


            <Label fx:id="messageLabel"/>
        </VBox>
    </center>

</BorderPane>
