<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.campusLink.controllers.Service_controller"
      spacing="25"
      style="-fx-background-color: #f5f7fa;"
      stylesheets="/Styles/student.css">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT">
        <Label text="Mes services" style="-fx-font-size: 26px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>

        <!-- Global translation button -->
        <Button fx:id="translateBtn"
                text="🌐 Traduire en anglais"
                onAction="#toggleTranslation"
                style="-fx-background-color: #EDECFD; -fx-text-fill: #5D5FEF;
                       -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-padding: 12 20; -fx-background-radius: 8;
                       -fx-cursor: hand; -fx-border-color: #c4b5fd;
                       -fx-border-width: 1; -fx-border-radius: 8;
                       -fx-margin: 0 10 0 0;"/>

        <Button text="+ Créer un nouveau service"
                onAction="#goToCreateService"
                style="-fx-background-color: #5D5FEF; -fx-text-fill: white;
                       -fx-font-size: 14px; -fx-padding: 12 24;
                       -fx-cursor: hand; -fx-background-radius: 8;
                       -fx-font-weight: bold;"/>
    </HBox>

    <!-- Search & Filters -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <TextField fx:id="searchField"
                   promptText="Rechercher un service..."
                   prefWidth="320"
                   style="-fx-background-color: white; -fx-border-color: #d1d5db;
                          -fx-border-radius: 8; -fx-background-radius: 8;
                          -fx-padding: 10 15; -fx-font-size: 14px;"/>

        <ComboBox fx:id="statusFilter" promptText="Statut" prefWidth="200"
                  style="-fx-background-color: white; -fx-border-color: #d1d5db;
                         -fx-border-radius: 8; -fx-background-radius: 8;"/>

        <ComboBox fx:id="categoryFilter" promptText="Catégorie" prefWidth="240"
                  style="-fx-background-color: white; -fx-border-color: #d1d5db;
                         -fx-border-radius: 8; -fx-background-radius: 8;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Button text="Réinitialiser" onAction="#resetFilters"
                style="-fx-background-color: #f3f4f6; -fx-text-fill: #6b7280;
                       -fx-font-size: 13px; -fx-padding: 10 16; -fx-cursor: hand;
                       -fx-background-radius: 8; -fx-border-color: #e5e7eb;
                       -fx-border-width: 1;"/>
    </HBox>

    <!-- Services Grid -->
    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" fitToHeight="false"
                style="-fx-background-color: transparent; -fx-background: transparent;
                       -fx-border-color: transparent;">
        <FlowPane fx:id="servicesContainer"
                  hgap="20" vgap="20" prefWrapLength="1340"
                  style="-fx-background-color: transparent; -fx-padding: 0 0 20 0;"/>
    </ScrollPane>

</VBox>
