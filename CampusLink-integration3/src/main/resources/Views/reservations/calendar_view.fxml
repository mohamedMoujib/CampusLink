<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.campusLink.controllers.reservations.CalendarViewController"
      stylesheets="/Styles/app.css"
      style="-fx-background-color:#f8f9fa;"
      prefWidth="800" prefHeight="600">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button text="← Réservations" onAction="#onBack"
                style="-fx-background-color:#f3f4f6; -fx-text-fill:#374151;
                       -fx-background-radius:8; -fx-padding:8 16; -fx-cursor:hand;"/>
        <Label text="Calendrier"
               style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="prevMonthBtn" text="◀"
                style="-fx-background-color:#f3f4f6; -fx-background-radius:8;
                       -fx-padding:8 14; -fx-cursor:hand;"/>
        <Label fx:id="monthYearLabel"
               style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
        <Button fx:id="nextMonthBtn" text="▶"
                style="-fx-background-color:#f3f4f6; -fx-background-radius:8;
                       -fx-padding:8 14; -fx-cursor:hand;"/>
    </HBox>

    <!-- Calendar grid -->
    <GridPane fx:id="calendarGrid" VBox.vgrow="ALWAYS"
              hgap="8" vgap="8"
              style="-fx-background-color:white; -fx-background-radius:12;
                     -fx-padding:16; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),8,0,0,2);">
    </GridPane>

</VBox>