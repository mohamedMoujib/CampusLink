<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="rootPane"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.campusLink.controllers.paiements.ViewInvoice"
           style="-fx-background-color:#f8f9fa;"
           stylesheets="/Styles/app.css">

    <VBox spacing="20">
        <padding>
            <Insets top="22" right="22" bottom="22" left="22"/>
        </padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="💳 Mes Factures"
                   style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="resultCountLabel" text=""
                   style="-fx-text-fill:#6b7280; -fx-font-size:13px;"/>
        </HBox>

        <!-- Stats bar -->
        <HBox spacing="16">
            <VBox spacing="4" alignment="CENTER"
                  style="-fx-background-color:white; -fx-background-radius:10;
                         -fx-border-color:#e5e7eb; -fx-border-radius:10;
                         -fx-padding:14 24;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),6,0,0,2);">
                <Label fx:id="lblTotalFactures" text="0"
                       style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                <Label text="Total factures"
                       style="-fx-text-fill:#6b7280; -fx-font-size:13px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Filter bar -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color:white; -fx-background-radius:10;
                     -fx-border-color:#e5e7eb; -fx-border-radius:10;
                     -fx-padding:14 16;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.04),6,0,0,2);">
            <TextField fx:id="searchField"
                       promptText="🔎 Rechercher (ID, détails...)"
                       prefWidth="260"
                       style="-fx-background-color:#f3f4f6;
                              -fx-background-radius:8;
                              -fx-border-color:transparent;
                              -fx-padding:8 12;"/>
            <DatePicker fx:id="startDatePicker"
                        promptText="Filtrer par date"
                        style="-fx-background-color:#f3f4f6;
                               -fx-background-radius:8;"/>
            <Button text="✕ Effacer" onAction="#onClearFilters"
                    style="-fx-background-color:#f3f4f6; -fx-text-fill:#6b7280;
                           -fx-background-radius:8; -fx-padding:8 14; -fx-cursor:hand;"/>
        </HBox>

        <!-- Table -->
        <TableView fx:id="invoiceTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-color:white; -fx-background-radius:12;
                          -fx-border-color:#e5e7eb; -fx-border-radius:12;">
            <columns>
                <TableColumn fx:id="paymentIdColumn" text="Payment ID" prefWidth="130"/>
                <TableColumn fx:id="dateColumn"      text="Date"       prefWidth="200"/>
                <TableColumn fx:id="detailsColumn"   text="Détails"    prefWidth="500"/>
            </columns>
            <placeholder>
                <Label text="Aucune facture trouvée."
                       style="-fx-text-fill:#9ca3af; -fx-font-size:14px;"/>
            </placeholder>
        </TableView>

        <!-- Actions -->
        <HBox spacing="12">
            <Button text="🗑 Supprimer la sélection" onAction="#deleteInvoice"
                    style="-fx-background-color:#fee2e2; -fx-text-fill:#dc2626;
                           -fx-font-weight:bold; -fx-background-radius:8;
                           -fx-padding:9 18; -fx-cursor:hand;"/>
            <Button text="👁 Aperçu" onAction="#previewInvoice"
                    style="-fx-background-color:#e0e7ff; -fx-text-fill:#4f46e5;
                           -fx-font-weight:bold; -fx-background-radius:8;
                           -fx-padding:9 18; -fx-cursor:hand;"/>
            <Button text="🔄 Actualiser" onAction="#onRefresh"
                    style="-fx-background-color:#f3f4f6; -fx-text-fill:#374151;
                           -fx-font-weight:bold; -fx-background-radius:8;
                           -fx-padding:9 18; -fx-cursor:hand;"/>
        </HBox>

    </VBox>

    <!-- Invoice preview modal (hidden by default) -->
    <VBox fx:id="previewOverlay"
          style="-fx-background-color:rgba(0,0,0,0.45);"
          alignment="CENTER"
          visible="false" managed="false">
        <VBox fx:id="previewCard" maxWidth="560"
              style="-fx-background-color:white; -fx-background-radius:16;
                     -fx-padding:28;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.18),20,0,0,6);"
              spacing="16">

            <HBox alignment="CENTER_LEFT">
                <Label text="📄 Détails de la facture"
                       style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="✕" onAction="#onClosePreview"
                        style="-fx-background-color:#f3f4f6; -fx-text-fill:#374151;
                               -fx-background-radius:20; -fx-padding:4 10; -fx-cursor:hand;"/>
            </HBox>

            <Separator/>

            <HBox spacing="12">
                <Label text="Payment ID :"
                       style="-fx-font-weight:bold; -fx-text-fill:#6b7280;"/>
                <Label fx:id="previewPaymentId" text=""
                       style="-fx-text-fill:#111827; -fx-font-weight:bold;"/>
            </HBox>

            <HBox spacing="12">
                <Label text="Date :"
                       style="-fx-font-weight:bold; -fx-text-fill:#6b7280;"/>
                <Label fx:id="previewDate" text=""
                       style="-fx-text-fill:#111827;"/>
            </HBox>

            <VBox spacing="6">
                <Label text="Détails :"
                       style="-fx-font-weight:bold; -fx-text-fill:#6b7280;"/>
                <Label fx:id="previewDetails" text=""
                       style="-fx-text-fill:#374151; -fx-wrap-text:true;"
                       maxWidth="500"/>
            </VBox>

            <HBox alignment="CENTER_RIGHT">
                <Button text="Fermer" onAction="#onClosePreview"
                        style="-fx-background-color:#4f46e5; -fx-text-fill:white;
                               -fx-font-weight:bold; -fx-background-radius:20;
                               -fx-padding:9 28; -fx-cursor:hand;"/>
            </HBox>
        </VBox>
    </VBox>

</StackPane>