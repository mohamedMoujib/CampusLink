<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane fx:id="rootPane"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.campusLink.controllers.users.ResetPasswordController"
           styleClass="root-pane"
           stylesheets="@/Styles/Login.css">

    <VBox alignment="CENTER" styleClass="background">

        <VBox styleClass="login-card"
              alignment="CENTER"
              spacing="20"
              maxWidth="400">

            <!-- Logo -->
            <StackPane styleClass="logo-circle">
                <Text text="🔑" styleClass="logo-icon"/>
            </StackPane>

            <!-- Title -->
            <VBox alignment="CENTER" spacing="5">
                <Text text="Nouveau mot de passe" styleClass="title"/>
                <Text text="Créez un nouveau mot de passe sécurisé"
                      styleClass="subtitle" textAlignment="CENTER"/>
            </VBox>

            <!-- New Password -->
            <VBox spacing="5">
                <Text text="Nouveau mot de passe" styleClass="label-text"/>
                <PasswordField fx:id="txtNewPassword"
                               promptText="••••••••"
                               styleClass="input-field-full"/>
                <Label fx:id="lblNewPasswordError"
                       styleClass="error-label"
                       managed="false"
                       visible="false"/>
                <Text text="Minimum 6 caractères"
                      style="-fx-fill: #9ca3af; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Confirm Password -->
            <VBox spacing="5">
                <Text text="Confirmer le mot de passe" styleClass="label-text"/>
                <PasswordField fx:id="txtConfirmPassword"
                               promptText="••••••••"
                               styleClass="input-field-full"/>
                <Label fx:id="lblConfirmPasswordError"
                       styleClass="error-label"
                       managed="false"
                       visible="false"/>
            </VBox>

            <!-- Password Strength Indicator -->
            <HBox spacing="5" alignment="CENTER_LEFT">
                <Text text="Force:" style="-fx-fill: #6b7280; -fx-font-size: 12px;"/>
                <ProgressBar fx:id="progressStrength"
                             prefWidth="150"
                             progress="0"
                             styleClass="password-strength"/>
                <Text fx:id="txtStrength"
                      text=""
                      style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
            </HBox>

            <!-- Reset Button -->
            <Button fx:id="btnReset"
                    text="Réinitialiser le mot de passe"
                    maxWidth="Infinity"
                    styleClass="btn-primary"
                    onAction="#handleResetPassword"/>

            <!-- Back to Login -->
            <Hyperlink fx:id="linkLogin"
                       text="← Retour à la connexion"
                       styleClass="link"
                       onAction="#handleBackToLogin"/>

            <VBox.margin>
                <Insets top="20" right="40" bottom="20" left="40"/>
            </VBox.margin>

        </VBox>
    </VBox>
</StackPane>
