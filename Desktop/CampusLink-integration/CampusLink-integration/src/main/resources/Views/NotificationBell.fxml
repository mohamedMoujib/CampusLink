<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.campusLink.controllers.NotificationBellController"
           prefWidth="40" prefHeight="40">

    <Button fx:id="bellButton"
            onAction="#togglePanel"
            style="-fx-background-color: transparent; -fx-cursor: hand;"
            prefWidth="32" prefHeight="32">
        <graphic>
            <Label text="🔔" style="-fx-font-size: 18px;"/>
        </graphic>
    </Button>

    <Label fx:id="badgeLabel"
           text="0"
           visible="false" managed="false"
           StackPane.alignment="TOP_RIGHT"
           style="-fx-background-color: #ef4444; -fx-text-fill: white;
                  -fx-font-size: 10px; -fx-font-weight: bold;
                  -fx-padding: 1 4; -fx-background-radius: 999px;
                  -fx-translate-x: -2; -fx-translate-y: 2;"/>

</StackPane>