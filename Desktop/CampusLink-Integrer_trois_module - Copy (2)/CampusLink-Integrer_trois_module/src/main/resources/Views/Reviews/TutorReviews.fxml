<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.campusLink.controllers.reviews.TutorReviewsController"
      spacing="20"
      style="-fx-padding: 40 60 40 60; -fx-background-color: #f8f9fa;"
      stylesheets="/Styles/reviews.css">

    <!-- Page Header avec statistiques -->
    <VBox spacing="15">
        <Label text="Avis reçus" styleClass="page-title"/>

        <!-- Statistiques -->
        <HBox spacing="20" alignment="CENTER">
            <VBox spacing="8" styleClass="stats-card" alignment="CENTER">
                <Label text="Note moyenne" style="-fx-font-size:13px; -fx-text-fill:#6b7280;"/>
                <HBox spacing="8" alignment="CENTER">
                    <Label fx:id="averageRatingLabel" text="4.5"
                           style="-fx-font-size:32px; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
                    <Label text="★" style="-fx-font-size:32px; -fx-text-fill:#fbbf24;"/>
                </HBox>
            </VBox>

            <VBox spacing="8" styleClass="stats-card" alignment="CENTER">
                <Label text="Total d'avis" style="-fx-font-size:13px; -fx-text-fill:#6b7280;"/>
                <Label fx:id="totalReviewsLabel" text="28"
                       style="-fx-font-size:32px; -fx-font-weight:bold; -fx-text-fill:#111827;"/>
            </VBox>

            <VBox spacing="8" styleClass="stats-card" alignment="CENTER">
                <Label text="Points de confiance" style="-fx-font-size:13px; -fx-text-fill:#6b7280;"/>
                <HBox spacing="8" alignment="CENTER">
                    <Label fx:id="trustPointsLabel" text="16"
                           style="-fx-font-size:32px; -fx-font-weight:bold; -fx-text-fill:#059669;"/>
                    <Label text="🏆" style="-fx-font-size:28px;"/>
                </HBox>
            </VBox>

            <VBox spacing="8" styleClass="stats-card" alignment="CENTER">
                <Label text="Ce mois-ci" style="-fx-font-size:13px; -fx-text-fill:#6b7280;"/>
                <Label fx:id="monthReviewsLabel" text="5"
                       style="-fx-font-size:32px; -fx-font-weight:bold; -fx-text-fill:#059669;"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- Filtres -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text="Filtrer par note :" style="-fx-font-weight:bold; -fx-font-size:14px;"/>
        <Button text="Tous" styleClass="filter-button-active-tutor" onAction="#filterAll"/>
        <Button text="⭐⭐⭐⭐⭐ 5" styleClass="filter-button" onAction="#filter5Stars"/>
        <Button text="⭐⭐⭐⭐ 4" styleClass="filter-button" onAction="#filter4Stars"/>
        <Button text="⭐⭐⭐ 3" styleClass="filter-button" onAction="#filter3Stars"/>
        <Button text="⭐⭐ 2-" styleClass="filter-button" onAction="#filterLow"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Label text="Traduire en :" style="-fx-font-weight:bold; -fx-font-size:14px;"/>
        <ComboBox fx:id="languageSelector" prefWidth="150" styleClass="filter-combo"/>
    </HBox>

    <!-- Liste des avis -->
    <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
        <VBox fx:id="reviewsContainer" spacing="20"/>
    </ScrollPane>

</VBox>