<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.campusLink.controllers.users.SignupController"
            styleClass="root-pane"
            stylesheets="@/Styles/Login.css">

    <fx:define>
        <ToggleGroup fx:id="roleGroup"/>
    </fx:define>

    <VBox alignment="CENTER" styleClass="background">

        <VBox styleClass="login-card"
              spacing="15"
              maxWidth="500">

            <!-- Header -->
            <VBox alignment="CENTER" spacing="3">
                <Text text="Créer un compte" styleClass="title"/>
                <Text text="Rejoignez CampusLink" styleClass="subtitle"/>
            </VBox>

            <!-- Role -->
            <HBox spacing="10" alignment="CENTER">
                <ToggleButton fx:id="btnEtudiant"
                              text="Étudiant"
                              toggleGroup="$roleGroup"
                              selected="true"
                              styleClass="role-btn-wide"/>

                <ToggleButton fx:id="btnTuteur"
                              text="Prestataire"
                              toggleGroup="$roleGroup"
                              styleClass="role-btn-wide"/>
            </HBox>

            <!-- Name -->
            <HBox spacing="10">
                <!-- Prénom -->
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <TextField fx:id="txtPrenom"
                               promptText="Prénom"
                               styleClass="input-field-compact"/>
                    <Label fx:id="lblPrenomError"
                           styleClass="error-label"
                           managed="false"
                           visible="false"/>
                </VBox>

                <!-- Nom -->
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <TextField fx:id="txtNom"
                               promptText="Nom"
                               styleClass="input-field-compact"/>
                    <Label fx:id="lblNomError"
                           styleClass="error-label"
                           managed="false"
                           visible="false"/>
                </VBox>
            </HBox>

            <!-- Email & Phone -->
            <HBox spacing="10">
                <!-- Email -->
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <TextField fx:id="txtEmail"
                               promptText="Email"
                               styleClass="input-field-compact"/>
                    <Label fx:id="lblEmailError"
                           styleClass="error-label"
                           managed="false"
                           visible="false"/>
                </VBox>

                <!-- Phone -->
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <TextField fx:id="txtPhone"
                               promptText="Téléphone"
                               styleClass="input-field-compact"/>
                    <Label fx:id="lblPhoneError"
                           styleClass="error-label"
                           managed="false"
                           visible="false"/>
                </VBox>
            </HBox>

            <!-- Gender & Address -->
            <HBox spacing="10">
                <!-- Gender -->
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <ComboBox fx:id="cmbGender"
                              promptText="Genre"
                              styleClass="input-field-compact"
                              maxWidth="Infinity"/>
                    <Label fx:id="lblGenderError"
                           styleClass="error-label"
                           managed="false"
                           visible="false"/>
                </VBox>

                <!-- Address -->
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <TextField fx:id="txtAddress"
                               promptText="Adresse"
                               styleClass="input-field-compact"/>
                    <Label fx:id="lblAddressError"
                           styleClass="error-label"
                           managed="false"
                           visible="false"/>
                </VBox>
            </HBox>

            <!-- University -->
            <VBox spacing="5">
                <TextField fx:id="txtUniversite"
                           promptText="Université"
                           styleClass="input-field-compact"/>
                <Label fx:id="lblUniversiteError"
                       styleClass="error-label"
                       managed="false"
                       visible="false"/>
            </VBox>

            <!-- Specialization & Filiere -->
            <HBox spacing="10">
                <!-- Specialization -->
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <TextField fx:id="txtSpecialization"
                               promptText="Spécialisation"
                               styleClass="input-field-compact"/>
                    <Label fx:id="lblSpecializationError"
                           styleClass="error-label"
                           managed="false"
                           visible="false"/>
                </VBox>

                <!-- Filiere -->
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <TextField fx:id="txtFiliere"
                               promptText="Filière"
                               styleClass="input-field-compact"/>
                    <Label fx:id="lblFiliereError"
                           styleClass="error-label"
                           managed="false"
                           visible="false"/>
                </VBox>
            </HBox>

            <!-- Password -->
            <HBox spacing="10">
                <!-- Password -->
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <PasswordField fx:id="txtPassword"
                                   promptText="Mot de passe"
                                   styleClass="input-field-compact"/>
                    <Label fx:id="lblPasswordError"
                           styleClass="error-label"
                           managed="false"
                           visible="false"/>
                </VBox>

                <!-- Confirm Password -->
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <PasswordField fx:id="txtConfirmPassword"
                                   promptText="Confirmer mot de passe"
                                   styleClass="input-field-compact"/>
                    <Label fx:id="lblConfirmPasswordError"
                           styleClass="error-label"
                           managed="false"
                           visible="false"/>
                </VBox>
            </HBox>

            <!-- Terms -->
            <CheckBox fx:id="chkTerms"
                      text="J'accepte les conditions et la confidentialité"
                      styleClass="checkbox"/>

            <!-- Button -->
            <Button fx:id="btnSignup"
                    text="Créer mon compte"
                    styleClass="btn-primary"
                    maxWidth="Infinity"
                    onAction="#handleSignup"/>

            <!-- Login -->
            <HBox alignment="CENTER" spacing="5">
                <Text text="Déjà un compte ?" styleClass="footer-text"/>
                <Hyperlink fx:id="linkLogin"
                           text="Se connecter"
                           styleClass="link-primary"
                           onAction="#handleLogin"/>
            </HBox>

            <padding>
                <Insets top="25" right="35" bottom="25" left="35"/>
            </padding>

        </VBox>

    </VBox>
</StackPane>
